<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>El-kretsen Intranät</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans h-screen flex flex-col">

    <div id="login-screen" class="flex flex-col items-center justify-center h-full">
        <div class="bg-white p-8 rounded-lg shadow-md w-96">
            <h1 class="text-2xl font-bold text-green-700 mb-6 text-center">El-kretsen Intranät</h1>
            <p class="text-sm text-gray-500 mb-4 text-center">Logga in för att få tillgång till dokument och ELvis.</p>
            
            <form id="login-form" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700">E-post / Användarnamn</label>
                    <input type="email" id="email" required class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700">Lösenord</label>
                    <input type="password" id="password" required class="mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-green-500 focus:border-green-500">
                </div>
                <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                    Logga in
                </button>
                <p id="error-message" class="text-red-500 text-sm hidden text-center mt-2"></p>
            </form>
        </div>
    </div>

    <div id="intranet-screen" class="hidden h-full flex flex-col">
        <header class="bg-green-700 text-white p-4 flex justify-between items-center shadow-md">
            <h1 class="text-xl font-bold">El-kretsen Intranät</h1>
            <button id="logout-btn" class="text-sm bg-green-800 hover:bg-green-900 px-3 py-1 rounded transition">Logga ut</button>
        </header>

        <div class="flex flex-1 overflow-hidden">
            
            <aside class="w-1/3 bg-white p-6 border-r border-gray-200 overflow-y-auto">
                <h2 class="text-lg font-semibold mb-4 text-gray-700">Interna Dokument</h2>
                <p class="text-sm text-gray-500 mb-4">Här hittar du snabblänkar till viktiga rutiner och filer.</p>
                
                <ul class="space-y-3" id="document-list">
                    <li>
                        <a href="#" class="flex items-center text-blue-600 hover:underline">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                            Rutiner för återvinning 2026.pdf
                        </a>
                    </li>
                    <li>
                        <a href="#" class="flex items-center text-blue-600 hover:underline">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                            Kontaktlista Personal.xlsx
                        </a>
                    </li>
                </ul>
            </aside>

            <main class="w-2/3 bg-gray-50 p-6 flex flex-col">
                <h2 class="text-lg font-semibold mb-4 text-gray-700">Fråga ELvis</h2>
                <div class="flex-1 bg-white rounded-lg shadow-inner overflow-hidden border border-gray-200">
                    <iframe 
                        src="https://elkretsen.zapier.app/" 
                        class="w-full h-full border-0"
                        title="ELvis Chatbot">
                    </iframe>
                </div>
            </main>
            
        </div>
    </div>

    <script>
        // 1. SUPABASE UPPGIFTER
        const SUPABASE_URL = 'https://jnwatbnkdzuyhqmcerej.supabase.co';
        // Byt ut texten nedan mot din riktiga anon key från Supabase (Project Settings -> API)
        const SUPABASE_ANON_KEY = 'KLISTRA_IN_DIN_ANON_KEY_HÄR'; 

        const supabase = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

        // UI Element
        const loginScreen = document.getElementById('login-screen');
        const intranetScreen = document.getElementById('intranet-screen');
        const loginForm = document.getElementById('login-form');
        const errorMsg = document.getElementById('error-message');
        const logoutBtn = document.getElementById('logout-btn');

        // 2. Kolla om användaren redan är inloggad när sidan laddas
        async function checkSession() {
            const { data: { session } } = await supabase.auth.getSession();
            if (session) {
                showIntranet();
            }
        }
        checkSession();

        // 3. Hantera Inloggning
        loginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorMsg.classList.add('hidden');
            
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            const { data, error } = await supabase.auth.signInWithPassword({
                email: email,
                password: password,
            });

            if (error) {
                errorMsg.textContent = 'Fel e-post eller lösenord. Försök igen.';
                errorMsg.classList.remove('hidden');
            } else {
                showIntranet();
            }
        });

        // 4. Hantera Utloggning
        logoutBtn.addEventListener('click', async () => {
            const { error } = await supabase.auth.signOut();
            if (!error) {
                loginScreen.classList.remove('hidden');
                intranetScreen.classList.add('hidden');
                document.getElementById('password').value = ''; // Rensa lösenordsfältet
            }
        });

        // Hjälpfunktion för att växla vy
        function showIntranet() {
            loginScreen.classList.add('hidden');
            intranetScreen.classList.remove('hidden');
        }
    </script>
</body>
</html>
